# JARVIS — AI Evolution Labs
# Copy to .env and fill only the providers you want to use.

# Required brain
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Default voice
FISH_API_KEY=your-fish-audio-api-key-here
FISH_VOICE_ID=612b878b113047d9a770c069c8b4fdfe

# Optional providers exposed by onboarding
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
HERMES_API_KEY=

# Active engine selection (set from the Settings → Engine panel, no restart needed)
# LLM brain: anthropic (default) | openai | ollama | google | deepseek | groq
JARVIS_LLM_PROVIDER=anthropic
# Voice: fish_audio (default) | elevenlabs
JARVIS_TTS_PROVIDER=fish_audio
# Local models — run `ollama serve`; no API key required
OLLAMA_BASE_URL=http://localhost:11434
# Optional per-provider model overrides, e.g.:
# JARVIS_LLM_MODEL_OPENAI=gpt-4o-mini
# JARVIS_LLM_MODEL_OLLAMA=llama3.2
# JARVIS_LLM_MODEL_GOOGLE=gemini-2.0-flash

# Personalization
USER_NAME=Tony
HONORIFIC=sir
CALENDAR_ACCOUNTS=auto
JARVIS_UI_LANGUAGE=en
JARVIS_RESPONSE_LANGUAGE=en
JARVIS_PERSONALITY_PRESET=stark
JARVIS_PERSONALITY_BRIEF=Act like Stark-style JARVIS: elegant British butler energy, loyal, concise, calm under pressure, dryly funny, and proactive without being intrusive.
JARVIS_HUMOR_LEVEL=balanced
JARVIS_FORMALITY_LEVEL=butler
JARVIS_PROACTIVE_MODE=smart

# Development/runtime
JARVIS_SKIP_PERMISSIONS=true

# Optional weather override
WEATHER_LOCATION_LABEL=
WEATHER_LATITUDE=
WEATHER_LONGITUDE=
WEATHER_UNIT=fahrenheit
