# -----------------------------------------------------------------------------
# Jervis by AJRUSZ Polska — provider onboarding
# Copy to .env or fill these from Settings in the web UI.
# -----------------------------------------------------------------------------

# Required: main AI brain
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Voice provider: fish or elevenlabs
TTS_PROVIDER=fish

# Fish Audio voice (default provider)
FISH_API_KEY=your-fish-audio-api-key-here
FISH_VOICE_ID=612b878b113047d9a770c069c8b4fdfe

# ElevenLabs voice (optional alternative TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# DeepSeek API (optional model provider / future agent workflows)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com

# Hermes agent gateway (optional custom/local agent endpoint)
HERMES_API_KEY=
HERMES_API_URL=

# User personalization
USER_NAME=Tony
HONORIFIC=sir

# Optional: Specific Apple Calendar accounts to read (comma-separated emails)
# If not set or set to auto, Jervis reads ALL calendars from Apple Calendar on macOS.
CALENDAR_ACCOUNTS=auto

# Optional: Whether to skip Claude CLI permission prompts on subprocess calls.
# Defaults to true because Jervis is voice-driven and cannot respond to prompts.
JARVIS_SKIP_PERMISSIONS=true

# Optional: Override the auto-detected weather location.
# WEATHER_LOCATION_LABEL=Austin, TX
# WEATHER_LATITUDE=30.2672
# WEATHER_LONGITUDE=-97.7431
# WEATHER_UNIT=fahrenheit  # or "celsius"
